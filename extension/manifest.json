{
  "manifest_version": 3,

  "name": "AutoXL AI Assistant",
  "version": "1.0",
  "key": "",

  "description": "AI-powered CSV training, prediction, and Google Sheets integration.",

  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "permissions": [
    "identity",
    "storage",
    "activeTab",
    "scripting",
    "tabs",
    "sidePanel"
  ],

  "host_permissions": [
    "http://localhost:8000/*",
    "https://www.googleapis.com/*"
  ],

  "oauth2": {
    "client_id": "34167525752-0kc2e62m121d95e8ri0mq2f960n52h51.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/spreadsheets.readonly"
    ]
  },

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_title": "AutoXL",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "side_panel": {
    "default_path": "sidepanel.html"
  },

  "content_scripts": [
    {
      "matches": ["https://docs.google.com/spreadsheets/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}